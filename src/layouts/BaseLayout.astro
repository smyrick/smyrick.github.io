---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Seo from '../components/Seo.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  path?: string;
  article?: boolean;
}

const { title, description, image, path, article } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fffaf3" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <Seo title={title} description={description} image={image} path={path} article={article} />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.getRegistrations().then((registrations) => {
            registrations.forEach((registration) => registration.unregister());
          });
          if (window.caches) {
            caches.keys().then((keys) => {
              keys
                .filter((key) => key.includes('gatsby') || key.includes('workbox'))
                .forEach((key) => caches.delete(key));
            });
          }
        });
      }
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
