---
import { site } from '../site';
---

<footer class="mx-auto w-full max-w-5xl px-5 py-10 text-sm text-[var(--color-muted)] sm:px-8">
  <div class="flex flex-col gap-3 border-t border-[var(--color-line)] pt-6 sm:flex-row sm:items-center sm:justify-between">
    <p>&copy; {new Date().getFullYear()} {site.name}</p>
    <div class="flex gap-4">
      {
        site.social.map((item) => (
          <a class="transition hover:text-[var(--color-accent-strong)]" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
