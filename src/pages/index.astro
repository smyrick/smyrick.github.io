---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../lib/posts';
import { site } from '../site';

const posts = await getPublishedPosts();
const latestPost = posts[0];
---

<BaseLayout title="Home" description={site.description} path="/">
  <section class="mx-auto grid min-h-[calc(100svh-10rem)] w-full max-w-5xl items-center gap-12 px-5 py-12 sm:px-8 lg:grid-cols-[1.05fr_0.95fr]">
    <div>
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-accent-strong)]">
        {site.location}
      </p>
      <h1 class="max-w-3xl text-5xl font-semibold leading-none text-[var(--color-ink)] sm:text-6xl lg:text-7xl">
        {site.name}
      </h1>
      <p class="mt-6 max-w-2xl text-xl leading-8 text-[var(--color-muted)]">
        {site.role} This is the quiet home base for contact, writing, and whatever is worth keeping outside the feed.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        {
          site.social.map((item) => (
            <a
              class="rounded-full border border-[var(--color-line)] bg-white/45 px-4 py-2 text-sm font-medium text-[var(--color-ink)] shadow-sm transition hover:border-[var(--color-accent)] hover:text-[var(--color-accent-strong)]"
              href={item.href}
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>

    <div class="mx-auto w-full max-w-sm lg:ml-auto">
      <img
        class="aspect-square w-full rounded-[2rem] border border-white/70 object-cover shadow-2xl shadow-[#9c7b5c]/20"
        src="/shane-profile.jpeg"
        alt="Shane Myrick"
        width="1301"
        height="1301"
      />
    </div>
  </section>

  <section class="mx-auto w-full max-w-5xl px-5 pb-16 sm:px-8">
    <div class="grid gap-6 border-t border-[var(--color-line)] pt-8 md:grid-cols-[0.7fr_1.3fr]">
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-accent-strong)]">
          Writing
        </h2>
      </div>
      <div>
        {
          latestPost ? (
            <a class="group block" href={latestPost.data.path}>
              <p class="text-sm text-[var(--color-muted)]">Latest post</p>
              <h3 class="mt-2 text-2xl font-semibold leading-tight text-[var(--color-ink)] transition group-hover:text-[var(--color-accent-strong)]">
                {latestPost.data.title}
              </h3>
              <p class="mt-3 max-w-2xl text-[var(--color-muted)]">
                Old notes stay public here. New writing shows up when it is useful enough to keep.
              </p>
            </a>
          ) : (
            <p class="text-[var(--color-muted)]">Writing archive coming back soon.</p>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
