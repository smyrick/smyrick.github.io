---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { profileImage } from '../lib/images';
import { site } from '../site';

const homeLinks = [...site.social];
const pillClass =
    'inline-flex items-center gap-[clamp(0.3rem,1vw,0.5rem)] rounded-full border border-[var(--color-line)] bg-white/55 px-[clamp(0.6rem,2vw,1rem)] py-[clamp(0.35rem,1.2vw,0.625rem)] text-[clamp(0.7rem,1.7vw,0.875rem)] font-semibold text-[var(--color-ink)] shadow-sm transition hover:-translate-y-0.5 hover:border-[var(--color-accent)] hover:text-[var(--color-accent-strong)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2';

const pillIcon = {
    GitHub: 'github',
    LinkedIn: 'linkedin',
    Email: 'mail',
} as const;
---

<BaseLayout title="Home" description={site.description} path="/">
    <section
        class="landing-hero mx-auto grid min-h-0 w-full max-w-5xl flex-1 grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] items-center gap-[clamp(0.75rem,3vw,3rem)] px-5 py-8 sm:px-8 sm:py-12"
    >
        <div class="portrait-stage" data-portrait-stage>
            <div class="portrait-plate" aria-hidden="true"></div>
            <div class="portrait-ring" aria-hidden="true"></div>
            <Image
                class="portrait-image"
                src={profileImage}
                alt="Shane Myrick"
                widths={[320, 460, 640, 920]}
                sizes="(max-width: 640px) 9rem, 24rem"
                loading="eager"
            />
        </div>

        <div>
            <p
                class="mb-[clamp(0.5rem,1.5vw,1rem)] text-[clamp(0.625rem,1.6vw,0.875rem)] font-semibold uppercase tracking-[0.18em] text-[var(--color-accent-strong)]"
            >
                {site.location}
            </p>
            <h1
                class="max-w-3xl text-[clamp(1.4rem,5.2vw,4.5rem)] font-semibold leading-none text-[var(--color-ink)]"
            >
                {site.name}
            </h1>
            <p
                class="mt-[clamp(0.75rem,2vw,1.5rem)] max-w-2xl text-[clamp(0.9rem,2.2vw,1.25rem)] leading-relaxed text-[var(--color-muted)]"
            >
                {site.role} This is the quiet home base for contact, writing, and
                whatever is worth keeping outside the feed.
            </p>
            <div
                class="mt-[clamp(1rem,3vw,2rem)] flex flex-wrap gap-[clamp(0.4rem,1.5vw,0.75rem)]"
            >
                {
                    homeLinks.map((item) => {
                        const icon = pillIcon[item.label as keyof typeof pillIcon];

                        return 'copy' in item ? (
                            <span
                                class="email-copy-wrap relative inline-flex"
                                data-copy-wrap
                            >
                                <button
                                    type="button"
                                    class={pillClass}
                                    data-copy-email={item.copy}
                                    aria-label={`Copy ${item.copy}`}
                                >
                                    {icon && <SocialIcon name={icon} />}
                                    {item.label}
                                </button>
                                <span
                                    class="email-copy-toast"
                                    data-copy-toast
                                    role="status"
                                    aria-live="polite"
                                />
                            </span>
                        ) : (
                            <a class={pillClass} href={item.href}>
                                {icon && <SocialIcon name={icon} />}
                                {item.label}
                            </a>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <script>
        const portraitStage = document.querySelector('[data-portrait-stage]');
        const reducedMotion = window.matchMedia(
            '(prefers-reduced-motion: reduce)'
        );

        if (portraitStage && !reducedMotion.matches) {
            portraitStage.addEventListener('pointermove', (event) => {
                const bounds = portraitStage.getBoundingClientRect();
                const x = (event.clientX - bounds.left) / bounds.width - 0.5;
                const y = (event.clientY - bounds.top) / bounds.height - 0.5;

                portraitStage.style.setProperty(
                    '--portrait-tilt-x',
                    `${y * -7}deg`
                );
                portraitStage.style.setProperty(
                    '--portrait-tilt-y',
                    `${x * 9}deg`
                );
                portraitStage.style.setProperty(
                    '--portrait-shift-x',
                    `${x * 14}px`
                );
                portraitStage.style.setProperty(
                    '--portrait-shift-y',
                    `${y * 14}px`
                );
                portraitStage.style.setProperty(
                    '--portrait-ring-x',
                    `${x * -7}px`
                );
                portraitStage.style.setProperty(
                    '--portrait-ring-y',
                    `${y * -7}px`
                );
            });

            portraitStage.addEventListener('pointerleave', () => {
                portraitStage.style.removeProperty('--portrait-tilt-x');
                portraitStage.style.removeProperty('--portrait-tilt-y');
                portraitStage.style.removeProperty('--portrait-shift-x');
                portraitStage.style.removeProperty('--portrait-shift-y');
                portraitStage.style.removeProperty('--portrait-ring-x');
                portraitStage.style.removeProperty('--portrait-ring-y');
            });
        }
    </script>

    <style>
        .email-copy-toast {
            position: absolute;
            top: calc(100% + 0.35rem);
            left: 0;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--color-accent-strong);
            white-space: nowrap;
            opacity: 0;
            transform: translateY(-0.25rem);
            pointer-events: none;
            transition:
                opacity 180ms ease,
                transform 180ms ease;
        }

        .email-copy-wrap.is-copied .email-copy-toast {
            opacity: 1;
            transform: translateY(0);
        }

        .portrait-stage {
            --portrait-tilt-x: 0deg;
            --portrait-tilt-y: 0deg;
            --portrait-shift-x: 0px;
            --portrait-shift-y: 0px;
            --portrait-ring-x: 0px;
            --portrait-ring-y: 0px;
            position: relative;
            width: 100%;
            max-width: 24rem;
            margin-inline: auto;
            aspect-ratio: 1;
            transform-style: preserve-3d;
            perspective: 56rem;
        }

        .portrait-image,
        .portrait-plate,
        .portrait-ring {
            position: absolute;
            left: 50%;
            top: 50%;
        }

        .portrait-image {
            z-index: 2;
            width: 88%;
            aspect-ratio: 1;
            height: auto;
            border: 1px solid rgba(255, 255, 255, 0.8);
            border-radius: clamp(0.85rem, 6%, 2rem);
            box-shadow: 0 2rem 5rem rgba(156, 123, 92, 0.24);
            object-fit: cover;
            transform: translate(-50%, -50%)
                translate3d(
                    var(--portrait-shift-x),
                    var(--portrait-shift-y),
                    2.5rem
                )
                rotateX(var(--portrait-tilt-x)) rotateY(var(--portrait-tilt-y))
                rotate(-2deg);
            transition: transform 180ms ease-out;
        }

        .portrait-plate {
            z-index: 0;
            width: 84%;
            aspect-ratio: 1;
            border-radius: clamp(0.95rem, 7%, 2.2rem);
            background: rgba(47, 111, 101, 0.14);
            transform: translate(-55%, -43%) rotate(-7deg);
        }

        .portrait-ring {
            z-index: 1;
            width: 80%;
            aspect-ratio: 1;
            border: 1px solid rgba(23, 76, 70, 0.32);
            border-radius: 999px;
            transform: translate(
                    calc(-42% + var(--portrait-ring-x)),
                    calc(-58% + var(--portrait-ring-y))
                )
                rotate(8deg);
            transition: transform 180ms ease-out;
        }

        @media (max-width: 640px) {
            .landing-hero {
                grid-template-columns:
                    minmax(0, 0.62fr)
                    minmax(0, 1.38fr);
            }

            .portrait-stage {
                max-width: 9rem;
            }
        }

        @media (max-width: 400px) {
            .landing-hero {
                grid-template-columns:
                    minmax(0, 0.5fr)
                    minmax(0, 1.5fr);
            }

            .portrait-stage {
                max-width: 7rem;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            .portrait-image,
            .portrait-ring {
                transition: none;
            }
        }
    </style>
</BaseLayout>
